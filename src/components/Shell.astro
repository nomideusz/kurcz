---
import Header from './Header.astro';
import Footer from './Footer.astro';
import CookieConsent from './CookieConsent.astro';
import TempsAnalytics from './TempsAnalytics.astro';
import ErrorTracking from './ErrorTracking.astro';

const { currentPath = '/' } = Astro.props;

const isTempsHost = Astro.site?.hostname.endsWith('rzeka.live') || false;
---

<Header currentPath={currentPath} />
<main class="flex-1">
  <slot />
</main>
<Footer />
<CookieConsent />
{isTempsHost && <TempsAnalytics />}
{isTempsHost && <ErrorTracking />}
