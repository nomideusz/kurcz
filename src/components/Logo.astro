---
// Brand wordmark — serif "kurcz.pl" with terracotta ".pl" (per design).
interface Props {
  class?: string;
  accentClass?: string;
}
const { class: className = 'text-2xl', accentClass = 'text-accent' } = Astro.props;
---

<span
  class:list={['inline-flex items-baseline font-serif font-medium tracking-tight text-ink', className]}
  >kurcz<span class:list={[accentClass]}>.pl</span></span
>
