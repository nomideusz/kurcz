---
import Logo from './Logo.astro';

const { currentPath = '/' } = Astro.props;

const nav = [
  { path: '/kurcze-miesniowe', label: 'przyczyny' },
  { path: '/pierwsza-pomoc', label: 'pierwsza pomoc' },
  { path: '/profilaktyka', label: 'profilaktyka' },
  { path: '/poradniki', label: 'poradniki' },
  { path: '/faq', label: 'faq' },
];

const isActive = (path) =>
  path === '/' ? currentPath === '/' : currentPath.startsWith(path);
---

<header
  class="sticky top-0 z-40 border-b border-line bg-paper/90 backdrop-blur supports-[backdrop-filter]:bg-paper/80"
>
  <div class="mx-auto flex h-[70px] max-w-7xl items-center justify-between px-5 sm:px-14">
    <a href="/" aria-label="Kurcz.pl — strona główna">
      <Logo class="text-[25px]" />
    </a>

    <nav class="hidden items-center gap-7 text-[15.5px] md:flex" aria-label="Główna nawigacja">
      {
        nav.map((item) => (
          <a
            href={item.path}
            class:list={[
              'transition-colors',
              isActive(item.path)
                ? 'border-b-2 border-accent pb-0.5 font-medium text-ink'
                : 'text-body hover:text-ink',
            ]}
            aria-current={isActive(item.path) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/kontakt"
        class="hidden rounded border border-ink px-[18px] py-[9px] text-sm font-medium text-ink transition-colors hover:bg-ink hover:text-paper sm:inline-block"
      >
        kontakt
      </a>

      <button
        type="button"
        id="menu-toggle"
        class="inline-flex items-center justify-center rounded-md p-2 text-ink md:hidden"
        aria-label="Otwórz menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-line bg-paper px-5 pb-4 md:hidden"
    aria-label="Nawigacja mobilna"
  >
    {
      [...nav, { path: '/kontakt', label: 'kontakt' }].map((item) => (
        <a
          href={item.path}
          class:list={[
            'block border-b border-line-soft py-3 text-base last:border-b-0',
            isActive(item.path) ? 'font-medium text-accent' : 'text-body',
          ]}
          aria-current={isActive(item.path) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById('menu-toggle');
    var menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;
    btn.addEventListener('click', function () {
      var open = menu.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(open));
    });
  })();
</script>
