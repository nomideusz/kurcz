---
// Native <details> accordion — accessible, zero JS.
// `bare`: render only the list (no <section>/heading), for embedding in a column.
const { items = [], heading = 'Najczęściej zadawane pytania', bare = false } = Astro.props;
---

{
  items.length > 0 &&
    (bare ? (
      <div>
        {items.map((item) => (
          <details class="group border-t border-line py-[22px] last:border-b last:border-line">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-5 marker:hidden">
              <h3 class="text-[18px] font-semibold text-ink">{item.question}</h3>
              <span class="font-serif text-xl leading-none text-accent transition-transform group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="mt-3 max-w-[600px] text-[15.5px] leading-relaxed text-muted">{item.answer}</p>
          </details>
        ))}
      </div>
    ) : (
      <section class="mx-auto max-w-3xl px-5 py-12 sm:px-14">
        <h2 class="text-3xl text-ink sm:text-[34px]">{heading}</h2>
        <div class="mt-6">
          {items.map((item) => (
            <details class="group border-t border-line py-[22px] last:border-b last:border-line">
              <summary class="flex cursor-pointer list-none items-start justify-between gap-5 marker:hidden">
                <h3 class="text-[18px] font-semibold text-ink">{item.question}</h3>
                <span class="font-serif text-xl leading-none text-accent transition-transform group-open:rotate-45">
                  +
                </span>
              </summary>
              <p class="mt-3 max-w-[640px] text-[15.5px] leading-relaxed text-muted">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    ))
}
