---
// Native <details> accordion — accessible, zero JS.
const { items = [], heading = 'Najczęściej zadawane pytania' } = Astro.props;
---

{
  items.length > 0 && (
    <section class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">{heading}</h2>
      <div class="mt-6 divide-y divide-slate-200 border-t border-slate-200">
        {items.map((item) => (
          <details class="group py-4">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-medium text-slate-900 marker:hidden">
              <span>{item.question}</span>
              <svg
                class="h-5 w-5 flex-shrink-0 text-slate-400 transition-transform group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 leading-relaxed text-slate-600">{item.answer}</p>
          </details>
        ))}
      </div>
    </section>
  )
}
