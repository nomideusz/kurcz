---
const { route } = Astro.props;

const crumbs = [{ path: '/', label: 'strona główna' }];
if (route.hubPath && route.hubLabel) {
  crumbs.push({ path: route.hubPath, label: route.hubLabel.toLowerCase() });
}
const current = (route.breadcrumbLabel ?? route.h1).toLowerCase();
---

{
  route.path !== '/' && (
    <nav
      aria-label="Ścieżka okruszków"
      class="mx-auto max-w-7xl px-5 pt-10 font-mono text-[12.5px] text-faint sm:px-14"
    >
      {crumbs.map((c) => (
        <>
          <a href={c.path} class="text-faint hover:text-ink">{c.label}</a>
          <span class="mx-1.5 text-[#c3b7a2]">/</span>
        </>
      ))}
      <span class="text-accent" aria-current="page">{current}</span>
    </nav>
  )
}
