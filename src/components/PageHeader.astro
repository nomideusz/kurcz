---
const { title, intro, eyebrow } = Astro.props;
---

<header class="mx-auto max-w-3xl px-4 pt-8 pb-2 sm:px-6">
  {eyebrow && <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-brand-700">{eyebrow}</p>}
  <h1 class="text-3xl font-bold leading-tight text-slate-900 sm:text-4xl">{title}</h1>
  {intro && <p class="mt-5 text-lg leading-relaxed text-slate-600">{intro}</p>}
</header>
