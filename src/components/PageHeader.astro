---
const { title, intro, eyebrow } = Astro.props;
---

<header class="border-b border-line">
  <div class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
    {eyebrow && <p class="eyebrow mb-4 text-accent">{eyebrow}</p>}
    <h1 class="max-w-[820px] text-4xl leading-[1.05] text-ink sm:text-5xl">{title}</h1>
    {intro && <p class="mt-5 max-w-[700px] text-lg leading-relaxed text-body">{intro}</p>}
  </div>
</header>
