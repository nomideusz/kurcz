---
const { links = [], heading = 'Powiązane tematy' } = Astro.props;
---

{
  links.length > 0 && (
    <nav aria-label={heading} class="mx-auto max-w-6xl px-5 pb-12 sm:px-8">
      <div class="eyebrow mb-4">{heading}</div>
      <ul class="flex flex-wrap gap-2.5">
        {links.map((l) => (
          <li>
            <a
              href={l.path}
              class="inline-flex rounded-full border border-line bg-card px-4 py-2 text-sm font-medium text-body transition-colors hover:border-accent-border hover:text-accent"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
