---
const { links = [], heading = 'Powiązane tematy' } = Astro.props;
---

{
  links.length > 0 && (
    <nav aria-label={heading} class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">{heading}</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {links.map((l) => (
          <li>
            <a
              href={l.path}
              class="inline-flex rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
