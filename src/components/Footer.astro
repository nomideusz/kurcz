---
import Logo from './Logo.astro';
import { footerLegalLinks } from '../seo/routes.js';

const topics = [
  { path: '/kurcze-miesniowe', label: 'przyczyny' },
  { path: '/pierwsza-pomoc', label: 'pierwsza pomoc' },
  { path: '/profilaktyka', label: 'profilaktyka' },
  { path: '/kurcz-vs-skurcz', label: 'kurcz vs skurcz' },
  { path: '/wibroakustyka', label: 'wibroakustyka' },
  { path: '/joga-a-kurcze', label: 'joga a kurcze' },
];

const serwis = [
  { path: '/poradniki', label: 'poradniki' },
  { path: '/faq', label: 'faq' },
  { path: '/kontakt', label: 'kontakt' },
  { path: '/o-nas', label: 'o nas' },
];

const partners = [
  { url: 'https://wibroakustyka.ai', label: 'Wibroakustyka.ai' },
  { url: 'https://kompi.pl', label: 'Kompi.pl' },
  { url: 'https://intertechpoland.pl', label: 'Intertech Poland' },
  { url: 'https://szkolyjogi.pl', label: 'Szkoły Jogi' },
];

const facebookUrl = 'https://www.facebook.com/profile.php?id=61575552422497';
const year = new Date().getFullYear();
---

<footer class="mt-20 bg-navy-deep text-[#a9b0bd]">
  <div class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
    <div class="grid gap-10 border-b border-[#243248] pb-9 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <a href="/" aria-label="Kurcz.pl — strona główna">
          <Logo class="text-[26px] text-[#f4efe6]" />
        </a>
        <p class="mt-3.5 max-w-[300px] text-sm leading-relaxed text-[#8b93a1]">
          Statyczna strona edukacyjna o kurczach mięśniowych — przyczyny, pierwsza pomoc
          i profilaktyka.
        </p>
      </div>

      <nav aria-label="Tematy">
        <div class="eyebrow mb-4 text-[#5e6878]">tematy</div>
        <ul class="flex flex-col gap-2.5 text-sm">
          {
            topics.map((l) => (
              <li>
                <a href={l.path} class="text-[#c2c8d2] hover:text-white">
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Serwis">
        <div class="eyebrow mb-4 text-[#5e6878]">serwis</div>
        <ul class="flex flex-col gap-2.5 text-sm">
          {
            serwis.map((l) => (
              <li>
                <a href={l.path} class="text-[#c2c8d2] hover:text-white">
                  {l.label}
                </a>
              </li>
            ))
          }
          {
            footerLegalLinks
              .filter((l) => ['/regulamin', '/polityka-prywatnosci', '/disclaimer-medyczny'].includes(l.path))
              .map((l) => (
                <li>
                  <a href={l.path} class="text-[#c2c8d2] hover:text-white">
                    {l.label.toLowerCase()}
                  </a>
                </li>
              ))
          }
        </ul>
      </nav>

      <nav aria-label="Partnerzy">
        <div class="eyebrow mb-4 text-[#5e6878]">partnerzy</div>
        <ul class="flex flex-col gap-2.5 text-sm">
          {
            partners.map((p) => (
              <li>
                <a
                  href={p.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-outbound={p.label}
                  class="text-[#c2c8d2] hover:text-white"
                >
                  {p.label}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href={facebookUrl}
              target="_blank"
              rel="noopener noreferrer"
              data-outbound="Facebook"
              class="text-[#c2c8d2] hover:text-white"
            >
              Facebook
            </a>
          </li>
        </ul>
      </nav>
    </div>

    <div class="flex flex-col items-start justify-between gap-5 pt-6 sm:flex-row">
      <p class="max-w-[620px] text-[12.5px] leading-relaxed text-[#6b7484]">
        Zastrzeżenie medyczne: informacje na tej stronie mają charakter edukacyjny i nie
        zastępują profesjonalnej konsultacji medycznej. W razie poważnych dolegliwości
        skonsultuj się z lekarzem.
      </p>
      <span class="font-mono text-xs whitespace-nowrap text-[#5e6878]">© {year} kurcz.pl</span>
    </div>
  </div>
</footer>

<script is:inline>
  // Track outbound clicks (footer partners + social) via consent-gated Umami.
  document.querySelectorAll('footer a[data-outbound]').forEach(function (a) {
    a.addEventListener('click', function () {
      if (typeof window.kurczTrack === 'function') {
        window.kurczTrack('outbound_click', {
          url: a.getAttribute('href'),
          label: a.getAttribute('data-outbound'),
          source: 'footer',
        });
      }
    });
  });
</script>
