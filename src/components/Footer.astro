---
import Logo from './Logo.astro';
import { footerLegalLinks } from '../seo/routes.js';

const topics = [
  { path: '/kurcze-miesniowe', label: 'przyczyny' },
  { path: '/pierwsza-pomoc', label: 'pierwsza pomoc' },
  { path: '/profilaktyka', label: 'profilaktyka' },
  { path: '/kurcz-vs-skurcz', label: 'kurcz vs skurcz' },
  { path: '/wibroakustyka', label: 'wibroakustyka' },
  { path: '/joga-a-kurcze', label: 'joga a kurcze' },
];

const serwis = [
  { path: '/poradniki', label: 'poradniki' },
  { path: '/faq', label: 'faq' },
  { path: '/kontakt', label: 'kontakt' },
  { path: '/o-nas', label: 'o nas' },
];

const partners = [
  { url: 'https://wibroakustyka.ai', label: 'Wibroakustyka.ai' },
  { url: 'https://kompi.pl', label: 'Kompi.pl' },
  { url: 'https://intertechpoland.pl', label: 'Intertech Poland' },
  { url: 'https://szkolyjogi.pl', label: 'Szkoły Jogi' },
];

const socials = [
  {
    label: 'Instagram',
    url: 'https://instagram.com/kurcz.pl',
    path: 'M12 2.2c3.2 0 3.6 0 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s0 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.2 15.58 2.2 15.2 2.2 12s0-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.2 8.8 2.2 12 2.2Zm0 1.8c-3.15 0-3.5 0-4.74.07-.9.04-1.38.19-1.7.32-.43.16-.74.36-1.06.68-.32.32-.52.63-.68 1.06-.13.32-.28.8-.32 1.7C3.8 8.5 3.8 8.85 3.8 12s0 3.5.07 4.74c.04.9.19 1.38.32 1.7.16.43.36.74.68 1.06.32.32.63.52 1.06.68.32.13.8.28 1.7.32 1.24.07 1.59.07 4.74.07s3.5 0 4.74-.07c.9-.04 1.38-.19 1.7-.32.43-.16.74-.36 1.06-.68.32-.32.52-.63.68-1.06.13-.32.28-.8.32-1.7.07-1.24.07-1.59.07-4.74s0-3.5-.07-4.74c-.04-.9-.19-1.38-.32-1.7a2.85 2.85 0 0 0-.68-1.06 2.85 2.85 0 0 0-1.06-.68c-.32-.13-.8-.28-1.7-.32C15.5 4 15.15 4 12 4Zm0 3.06a4.94 4.94 0 1 1 0 9.88 4.94 4.94 0 0 1 0-9.88Zm0 1.8a3.14 3.14 0 1 0 0 6.28 3.14 3.14 0 0 0 0-6.28Zm5.14-.66a1.15 1.15 0 1 1 0 2.3 1.15 1.15 0 0 1 0-2.3Z',
  },
  {
    label: 'Facebook',
    url: 'https://www.facebook.com/profile.php?id=61575552422497',
    path: 'M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.99 3.66 9.13 8.44 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.45 2.89h-2.33v6.99C18.34 21.13 22 16.99 22 12Z',
  },
];

const year = new Date().getFullYear();
---

<footer class="mt-20 bg-navy-deep text-[#a9b0bd]">
  <div class="mx-auto max-w-7xl px-5 py-14 sm:px-14">
    <div class="grid gap-10 border-b border-[#243248] pb-9 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <a href="/" aria-label="Kurcz.pl — strona główna">
          <Logo class="text-[26px] text-[#f4efe6]" />
        </a>
        <p class="mt-3.5 max-w-[300px] text-sm leading-relaxed text-[#8b93a1]">
          Statyczna strona edukacyjna o kurczach mięśniowych — przyczyny, pierwsza pomoc
          i profilaktyka.
        </p>
      </div>

      <nav aria-label="Tematy">
        <div class="eyebrow mb-4 text-[#5e6878]">tematy</div>
        <ul class="flex flex-col gap-2.5 text-sm">
          {
            topics.map((l) => (
              <li>
                <a href={l.path} class="text-[#c2c8d2] hover:text-white">
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Serwis">
        <div class="eyebrow mb-4 text-[#5e6878]">serwis</div>
        <ul class="flex flex-col gap-2.5 text-sm">
          {
            serwis.map((l) => (
              <li>
                <a href={l.path} class="text-[#c2c8d2] hover:text-white">
                  {l.label}
                </a>
              </li>
            ))
          }
          {
            footerLegalLinks
              .filter((l) => ['/regulamin', '/polityka-prywatnosci', '/disclaimer-medyczny'].includes(l.path))
              .map((l) => (
                <li>
                  <a href={l.path} class="text-[#c2c8d2] hover:text-white">
                    {l.label.toLowerCase()}
                  </a>
                </li>
              ))
          }
        </ul>
      </nav>

      <nav aria-label="Partnerzy">
        <div class="eyebrow mb-4 text-[#5e6878]">partnerzy</div>
        <ul class="flex flex-col gap-2.5 text-sm">
          {
            partners.map((p) => (
              <li>
                <a
                  href={p.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-outbound={p.label}
                  class="text-[#c2c8d2] hover:text-white"
                >
                  {p.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div class="flex flex-col items-start justify-between gap-5 pt-6 sm:flex-row sm:items-center">
      <p class="max-w-[560px] text-[12.5px] leading-relaxed text-[#6b7484]">
        Zastrzeżenie medyczne: informacje na tej stronie mają charakter edukacyjny i nie
        zastępują profesjonalnej konsultacji medycznej. W razie poważnych dolegliwości
        skonsultuj się z lekarzem.
      </p>
      <div class="flex items-center gap-5">
        <div class="flex items-center gap-2.5">
          {
            socials.map((s) => (
              <a
                href={s.url}
                target="_blank"
                rel="noopener noreferrer"
                data-outbound={s.label}
                aria-label={s.label}
                class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-[#2c3a52] text-[#c2c8d2] transition-colors hover:border-accent hover:text-white"
              >
                <svg class="h-[18px] w-[18px]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d={s.path} />
                </svg>
              </a>
            ))
          }
        </div>
        <span class="font-mono text-xs whitespace-nowrap text-[#5e6878]">© {year} kurcz.pl</span>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  // Track outbound clicks (footer partners + social) via consent-gated Umami.
  document.querySelectorAll('footer a[data-outbound]').forEach(function (a) {
    a.addEventListener('click', function () {
      if (typeof window.kurczTrack === 'function') {
        window.kurczTrack('outbound_click', {
          url: a.getAttribute('href'),
          label: a.getAttribute('data-outbound'),
          source: 'footer',
        });
      }
    });
  });
</script>
