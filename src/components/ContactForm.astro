---
// Posts to /api/contact (Node endpoint → Stalwart SMTP). No client-side mail SDK.
---

<form id="contact-form" class="space-y-5" novalidate>
  <div>
    <label for="cf-name" class="block text-sm font-medium text-ink">Imię</label>
    <input
      id="cf-name"
      name="from_name"
      type="text"
      required
      autocomplete="name"
      class="mt-1.5 block w-full rounded-md border border-line bg-card px-3.5 py-2.5 text-ink focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
    />
  </div>
  <div>
    <label for="cf-email" class="block text-sm font-medium text-ink">Adres e-mail</label>
    <input
      id="cf-email"
      name="reply_to"
      type="email"
      required
      autocomplete="email"
      class="mt-1.5 block w-full rounded-md border border-line bg-card px-3.5 py-2.5 text-ink focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
    />
  </div>
  <div>
    <label for="cf-message" class="block text-sm font-medium text-ink">Wiadomość</label>
    <textarea
      id="cf-message"
      name="message"
      rows="5"
      required
      class="mt-1.5 block w-full rounded-md border border-line bg-card px-3.5 py-2.5 text-ink focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
    ></textarea>
  </div>

  <!-- Honeypot: hidden from humans, bots fill it -->
  <div class="absolute -left-[5000px]" aria-hidden="true">
    <label>Nie wypełniaj tego pola<input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
  </div>

  <button
    type="submit"
    id="cf-submit"
    class="rounded-md bg-accent px-[26px] py-[13px] text-[15px] font-medium text-paper hover:bg-accent-light disabled:cursor-not-allowed disabled:opacity-60"
  >
    Wyślij wiadomość
  </button>
  <p id="cf-status" role="status" aria-live="polite" class="text-sm"></p>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    const status = document.getElementById('cf-status')!;
    const submit = document.getElementById('cf-submit') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      submit.disabled = true;
      status.textContent = 'Wysyłanie…';
      status.className = 'text-sm text-muted';

      const payload = Object.fromEntries(new FormData(form).entries());

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) {
          status.textContent = 'Dziękujemy! Twoja wiadomość została wysłana.';
          status.className = 'text-sm text-accent';
          (window as any).kurczTrack?.('contact_form_submit', { path: location.pathname });
          form.reset();
        } else {
          status.textContent =
            data.error ?? 'Nie udało się wysłać wiadomości. Spróbuj ponownie.';
          status.className = 'text-sm text-red-600';
          (window as any).kurczTrack?.('contact_form_error', { path: location.pathname });
        }
      } catch {
        status.textContent = 'Błąd połączenia. Spróbuj ponownie za chwilę.';
        status.className = 'text-sm text-red-600';
        (window as any).kurczTrack?.('contact_form_error', { path: location.pathname });
      } finally {
        submit.disabled = false;
      }
    });
  }
</script>
