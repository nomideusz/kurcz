---
import { emailConfig } from '../config.js';
const { publicKey, serviceId, templateId } = emailConfig.emailjs;
---

<form
  id="contact-form"
  class="space-y-5"
  data-public-key={publicKey}
  data-service-id={serviceId}
  data-template-id={templateId}
  novalidate
>
  <div>
    <label for="cf-name" class="block text-sm font-medium text-slate-700">Imię</label>
    <input
      id="cf-name"
      name="from_name"
      type="text"
      required
      autocomplete="name"
      class="mt-1.5 block w-full rounded-md border border-slate-300 px-3 py-2.5 text-slate-900 shadow-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
    />
  </div>
  <div>
    <label for="cf-email" class="block text-sm font-medium text-slate-700">Adres e-mail</label>
    <input
      id="cf-email"
      name="reply_to"
      type="email"
      required
      autocomplete="email"
      class="mt-1.5 block w-full rounded-md border border-slate-300 px-3 py-2.5 text-slate-900 shadow-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
    />
  </div>
  <div>
    <label for="cf-message" class="block text-sm font-medium text-slate-700">Wiadomość</label>
    <textarea
      id="cf-message"
      name="message"
      rows="5"
      required
      class="mt-1.5 block w-full rounded-md border border-slate-300 px-3 py-2.5 text-slate-900 shadow-sm focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
    ></textarea>
  </div>
  <button
    type="submit"
    id="cf-submit"
    class="rounded-md bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-700 disabled:cursor-not-allowed disabled:opacity-60"
  >
    Wyślij wiadomość
  </button>
  <p id="cf-status" role="status" aria-live="polite" class="text-sm"></p>
</form>

<script>
  import emailjs from '@emailjs/browser';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    const status = document.getElementById('cf-status')!;
    const submit = document.getElementById('cf-submit') as HTMLButtonElement;
    const publicKey = form.dataset.publicKey!;
    const serviceId = form.dataset.serviceId!;
    const templateId = form.dataset.templateId!;

    emailjs.init({ publicKey });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      submit.disabled = true;
      status.textContent = 'Wysyłanie…';
      status.className = 'text-sm text-slate-500';
      try {
        await emailjs.sendForm(serviceId, templateId, form);
        status.textContent = 'Dziękujemy! Twoja wiadomość została wysłana.';
        status.className = 'text-sm text-brand-700';
        (window as any).kurczTrack?.('contact_form_submit', { path: location.pathname });
        form.reset();
      } catch (err) {
        status.textContent =
          'Nie udało się wysłać wiadomości. Spróbuj ponownie lub napisz bezpośrednio na e-mail.';
        status.className = 'text-sm text-red-600';
        (window as any).kurczTrack?.('contact_form_error', { path: location.pathname });
      } finally {
        submit.disabled = false;
      }
    });
  }
</script>
