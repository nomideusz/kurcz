---
import Layout from '../layouts/Layout.astro';
import Shell from '../components/Shell.astro';
import { getRouteByPath } from '../seo/routes.js';

const route = getRouteByPath('/');

const topics = [
  {
    path: '/kurcze-miesniowe',
    title: 'Kurcze mięśniowe',
    desc: 'Czym są kurcze, najczęstsze przyczyny, objawy i czynniki ryzyka.',
  },
  {
    path: '/pierwsza-pomoc',
    title: 'Pierwsza pomoc',
    desc: 'Co robić w trakcie bolesnego kurczu — rozciąganie, masaż, nawodnienie.',
  },
  {
    path: '/profilaktyka',
    title: 'Profilaktyka',
    desc: 'Jak zapobiegać nawrotom: nawodnienie, dieta, rozciąganie i nawyki.',
  },
  {
    path: '/kurcz-vs-skurcz',
    title: 'Kurcz a skurcz',
    desc: 'Różnice terminologiczne i medyczne między kurczem a skurczem mięśni.',
  },
  {
    path: '/poradniki',
    title: 'Poradniki',
    desc: 'Praktyczne artykuły: kurcze łydek, nocne, niedobór magnezu i więcej.',
  },
  {
    path: '/faq',
    title: 'Najczęstsze pytania',
    desc: 'Odpowiedzi na pytania o leki, kurcze nocne, witaminy i konsultacje.',
  },
];
---

<Layout route={route}>
  <Shell currentPath="/">
    <!-- Hero -->
    <section class="border-b border-slate-200 bg-slate-50">
      <div class="mx-auto grid max-w-6xl items-center gap-10 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:gap-14 lg:py-24">
        <div>
          <p class="mb-4 text-sm font-semibold uppercase tracking-wide text-brand-700">
            Wiedza o kurczach mięśniowych
          </p>
          <h1 class="text-4xl font-bold leading-tight text-slate-900 sm:text-5xl">
            Zrozumieć kurcze mięśniowe
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-600">
            Rzetelna, edukacyjna wiedza w jednym miejscu. Poznaj przyczyny bolesnych
            kurczy nóg i mięśni, dowiedz się, jak szybko znaleźć ulgę oraz skutecznie
            zapobiegać ich nawrotom.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="/pierwsza-pomoc"
              class="rounded-md bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-700"
            >
              Pierwsza pomoc przy kurczu
            </a>
            <a
              href="/poradniki"
              class="rounded-md border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50"
            >
              Przeglądaj poradniki
            </a>
          </div>
        </div>
        <div>
          <img
            src="/img/hero.webp"
            width="1400"
            height="1049"
            alt="Rozluźnianie napiętego mięśnia łydki rollerem — ulga przy kurczach"
            fetchpriority="high"
            class="w-full rounded-xl border border-slate-200 object-cover shadow-sm"
          />
        </div>
      </div>
    </section>

    <!-- Topic grid -->
    <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">Od czego zacząć</h2>
      <p class="mt-2 text-slate-600">Wybierz temat, który Cię interesuje.</p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          topics.map((t) => (
            <a
              href={t.path}
              class="group flex h-full flex-col rounded-lg border border-slate-200 bg-white p-6 transition-colors hover:border-brand-300 hover:bg-brand-50/40"
            >
              <span class="text-lg font-semibold text-slate-900 group-hover:text-brand-700">
                {t.title}
              </span>
              <span class="mt-2 text-sm leading-relaxed text-slate-600">{t.desc}</span>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Medical note -->
    <section class="mx-auto max-w-5xl px-4 pb-16 sm:px-6">
      <div class="rounded-lg border border-brand-200 bg-brand-50/60 p-6">
        <h2 class="text-base font-semibold text-slate-900">
          Kiedy skonsultować się z lekarzem
        </h2>
        <p class="mt-2 text-sm leading-relaxed text-slate-600">
          Pojedyncze, krótkotrwałe kurcze zwykle nie są groźne. Jeśli jednak kurcze
          nawracają, są bardzo bolesne, długotrwałe lub towarzyszą im inne objawy —
          skonsultuj się z lekarzem. Treści w serwisie mają charakter edukacyjny i nie
          zastępują porady medycznej.
        </p>
      </div>
    </section>
  </Shell>
</Layout>
