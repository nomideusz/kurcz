---
import Layout from '../layouts/Layout.astro';
import Shell from '../components/Shell.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import { getRouteByPath } from '../seo/routes.js';
import { faqItems } from '../seo/faq-data.js';

const route = getRouteByPath('/');

const reliefSteps = [
  { n: 1, title: 'Rozciągnij mięsień', body: 'Delikatnie wyprostuj kończynę i przytrzymaj 20–30 sekund, oddychając głęboko.' },
  { n: 2, title: 'Nawodnij się', body: 'Uzupełnij elektrolity — woda z solą mineralną lub napój izotoniczny.' },
  { n: 3, title: 'Rozmasuj', body: 'Okrężne, delikatne ruchy z rosnącym naciskiem aż do rozluźnienia.' },
];

const topics = [
  { n: '01', path: '/kurcze-miesniowe', title: 'Przyczyny kurczy', desc: 'Odwodnienie, niedobory minerałów i przeciążenie — co naprawdę wywołuje kurcze.' },
  { n: '02', path: '/pierwsza-pomoc', title: 'Pierwsza pomoc', desc: 'Trzy kroki natychmiastowej ulgi, rozciąganie, masaż oraz terapia ciepłem i zimnem.' },
  { n: '03', path: '/profilaktyka', title: 'Profilaktyka', desc: 'Nawodnienie, dieta bogata w elektrolity i rozciąganie, które zapobiegają nawrotom.' },
  { n: '04', path: '/kurcz-vs-skurcz', title: 'Kurcz vs skurcz', desc: 'Czym różnią się te dwa terminy — i dlaczego nie znaczą tego samego.' },
  { n: '05', path: '/wibroakustyka', title: 'Wibroakustyka', desc: 'Terapia częstotliwościami dźwięku jako uzupełnienie profilaktyki kurczy.' },
  { n: '06', path: '/joga-a-kurcze', title: 'Joga a kurcze', desc: 'Asany, świadomy oddech i lepsze ukrwienie w służbie elastycznych mięśni.' },
];

const doctorSigns = [
  'Kurcze utrzymujące się ponad 10 minut',
  'Częste, nawracające mimo profilaktyki',
  'Obrzęk, zaczerwienienie lub silny ból',
  'Kurcze po urazie lub z innymi objawami',
];

const homeFaq = faqItems.slice(0, 4);
---

<Layout route={route}>
  <Shell currentPath="/">
    <!-- HERO -->
    <section class="mx-auto grid max-w-6xl items-center gap-12 px-5 py-16 sm:px-8 lg:grid-cols-[1.15fr_0.85fr] lg:gap-14 lg:py-[72px]">
      <div>
        <div class="eyebrow mb-5 flex items-center gap-2.5 text-[#8a7f6e]">
          <span class="h-px w-[22px] bg-[#c9b79b]"></span>poradnik zdrowia · mięśnie
        </div>
        <h1 class="text-5xl leading-[1.02] text-ink sm:text-6xl lg:text-[70px] lg:leading-[1.02]">
          Co robić, gdy złapie&nbsp;<em class="text-accent not-italic [font-style:italic]">kurcz</em> mięśnia.
        </h1>
        <p class="mt-6 max-w-[480px] text-lg leading-relaxed text-body">
          Rzetelne i proste informacje o przyczynach, natychmiastowej uldze oraz
          zapobieganiu bolesnym kurczom mięśniowym — zgodne z aktualną wiedzą medyczną.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3.5">
          <a
            href="/pierwsza-pomoc"
            class="inline-flex items-center gap-2 rounded-md bg-accent px-[26px] py-[15px] text-[15px] font-medium text-paper transition-colors hover:bg-accent-light"
          >
            pierwsza pomoc <span class="text-[17px]">→</span>
          </a>
          <a
            href="/kurcze-miesniowe"
            class="rounded-md border border-[#cfc6b5] px-[22px] py-[15px] text-[15px] font-medium text-ink transition-colors hover:border-ink"
          >
            poznaj przyczyny
          </a>
        </div>
      </div>

      <!-- Quick relief card -->
      <div class="rounded-[10px] border border-line bg-card p-[30px] shadow-[0_1px_2px_rgba(24,36,56,.04),0_12px_30px_rgba(24,36,56,.06)]">
        <div class="mb-5 flex items-center justify-between">
          <span class="eyebrow text-accent">szybka ulga</span>
          <span class="font-mono text-[11.5px] text-faint">3 kroki</span>
        </div>
        <div class="flex flex-col">
          {
            reliefSteps.map((s) => (
              <div class="flex gap-4 border-t border-line-soft py-4">
                <span class="w-[26px] flex-none font-serif text-2xl leading-none text-accent">{s.n}</span>
                <div>
                  <div class="mb-1 text-[15px] font-semibold text-ink">{s.title}</div>
                  <div class="text-[13.5px] leading-relaxed text-muted">{s.body}</div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- TOPICS -->
    <section class="mx-auto max-w-6xl px-5 pb-[72px] sm:px-8">
      <div class="mb-7 flex items-end justify-between">
        <h2 class="text-3xl text-ink sm:text-[34px]">Tematy</h2>
        <span class="font-mono text-xs text-faint">06 zagadnień</span>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          topics.map((t) => (
            <a
              href={t.path}
              class="group flex min-h-[172px] flex-col rounded-[9px] border border-line bg-card p-6 transition-[border-color,transform] hover:-translate-y-0.5 hover:border-accent-border"
            >
              <span class="font-mono text-xs text-[#b5a992]">{t.n}</span>
              <h3 class="mt-3.5 mb-2 text-2xl text-ink">{t.title}</h3>
              <p class="mb-auto text-sm leading-relaxed text-muted">{t.desc}</p>
              <span class="mt-3.5 text-sm text-accent">czytaj →</span>
            </a>
          ))
        }
      </div>
    </section>

    <!-- WHEN TO SEE A DOCTOR -->
    <section class="mx-auto max-w-6xl px-5 pb-[72px] sm:px-8">
      <div class="grid items-center gap-12 rounded-xl bg-navy px-8 py-12 sm:px-13 md:grid-cols-2">
        <div>
          <div class="eyebrow mb-4 text-accent-light">uwaga</div>
          <h2 class="mb-3 text-3xl leading-tight text-[#f4efe6] sm:text-4xl">
            Kiedy skontaktować się z lekarzem?
          </h2>
          <p class="text-[15.5px] leading-relaxed text-[#a9b0bd]">
            Większość kurczy mija samoistnie. Są jednak sytuacje, w których warto zgłosić
            się po pomoc specjalisty.
          </p>
        </div>
        <ul class="flex flex-col">
          {
            doctorSigns.map((s) => (
              <li class="flex gap-3.5 border-t border-[#2c3a52] py-3.5 text-[15px] text-[#d9dce2]">
                <span class="font-semibold text-accent">·</span>
                {s}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mx-auto max-w-6xl px-5 pb-[76px] sm:px-8">
      <div class="grid gap-12 lg:grid-cols-[0.7fr_1.3fr]">
        <div>
          <h2 class="mb-3 text-3xl text-ink sm:text-[34px]">Najczęstsze pytania</h2>
          <p class="text-[15px] leading-relaxed text-muted">
            Krótkie odpowiedzi na to, o co pytacie najczęściej.
          </p>
          <a href="/faq" class="mt-5 inline-block text-sm text-accent hover:text-accent-light">
            zobacz wszystkie pytania →
          </a>
        </div>
        <FaqAccordion items={homeFaq} bare />
      </div>
    </section>
  </Shell>
</Layout>
