---
import Layout from '../layouts/Layout.astro';
import Shell from '../components/Shell.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageHeader from '../components/PageHeader.astro';
import { poradnikiHub, poradnikiHubRoute } from '../content/poradniki-hub.js';

const route = poradnikiHubRoute;
const { categories } = poradnikiHub;
---

<Layout route={route}>
  <Shell currentPath="/poradniki">
    <Breadcrumbs route={route} />
    <PageHeader title={poradnikiHub.h1} intro={poradnikiHub.intro} />

    <div class="mx-auto max-w-7xl px-5 py-12 sm:px-14">
      {
        categories.map((category) => (
          <section class="mb-14">
            <h2 class="text-2xl text-ink sm:text-[28px]">{category.title}</h2>
            <p class="mt-2 max-w-[680px] text-muted">{category.description}</p>
            <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {category.guides.map((guide) => (
                <li>
                  <a
                    href={guide.path}
                    class="group flex h-full flex-col rounded-[9px] border border-line bg-card p-6 transition-[border-color,transform] hover:-translate-y-0.5 hover:border-accent-border"
                  >
                    <h3 class="text-xl leading-snug text-ink">{guide.title}</h3>
                    <span class="mt-2 mb-auto text-sm leading-relaxed text-muted">
                      {guide.description}
                    </span>
                    <span class="mt-4 text-sm text-accent">czytaj →</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </Shell>
</Layout>
