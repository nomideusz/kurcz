---
import Layout from '../layouts/Layout.astro';
import Shell from '../components/Shell.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageHeader from '../components/PageHeader.astro';
import { poradnikiHub, poradnikiHubRoute } from '../content/poradniki-hub.js';

const route = poradnikiHubRoute;
const { categories } = poradnikiHub;
---

<Layout route={route}>
  <Shell currentPath="/poradniki">
    <Breadcrumbs route={route} />
    <PageHeader title={poradnikiHub.h1} intro={poradnikiHub.intro} />

    <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
      {
        categories.map((category) => (
          <section class="mb-12">
            <h2 class="text-xl font-semibold text-slate-900">{category.title}</h2>
            <p class="mt-2 text-slate-600">{category.description}</p>
            <ul class="mt-6 grid gap-4 sm:grid-cols-2">
              {category.guides.map((guide) => (
                <li>
                  <a
                    href={guide.path}
                    class="group flex h-full flex-col rounded-lg border border-slate-200 bg-white p-5 transition-colors hover:border-brand-300 hover:bg-brand-50/40"
                  >
                    <span class="font-semibold text-slate-900 group-hover:text-brand-700">
                      {guide.title}
                    </span>
                    <span class="mt-2 text-sm leading-relaxed text-slate-600">
                      {guide.description}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </Shell>
</Layout>
