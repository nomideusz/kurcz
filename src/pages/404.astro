---
import Layout from '../layouts/Layout.astro';
import Shell from '../components/Shell.astro';

const route = {
  path: '/404',
  type: 'static',
  h1: 'Strona nie została znaleziona',
  breadcrumbLabel: '404',
  title: 'Strona nie znaleziona (404) | Kurcz.pl',
  description: 'Nie znaleźliśmy tej strony. Wróć na stronę główną lub przejrzyj poradniki o kurczach mięśniowych.',
};
---

<Layout route={route}>
  <Shell currentPath="/404">
    <section class="mx-auto max-w-2xl px-4 py-24 text-center sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-wide text-brand-700">Błąd 404</p>
      <h1 class="mt-3 text-3xl font-bold text-slate-900 sm:text-4xl">
        Strona nie została znaleziona
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-slate-600">
        Strona, której szukasz, nie istnieje lub została przeniesiona.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/" class="rounded-md bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-brand-700">
          Strona główna
        </a>
        <a href="/poradniki" class="rounded-md border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50">
          Poradniki
        </a>
      </div>
    </section>
  </Shell>
</Layout>
