# Contact form → Stalwart SMTP submission (set these as CapRover env variables).
# The /api/contact endpoint reads these at runtime.

SMTP_HOST=mail.zaur.app
# 465 = implicit TLS, 587 = STARTTLS
SMTP_PORT=465
# Stalwart account / app password used only for sending
SMTP_USER=
SMTP_PASS=
# Inbox that receives contact messages (defaults to SMTP_USER if unset)
CONTACT_TO=
# From address — must be a domain Stalwart is allowed to send as
CONTACT_FROM=Kurcz.pl <kontakt@kurcz.pl>
